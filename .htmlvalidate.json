{
  "extends": ["html-validate:recommended"],
  "rules": {
    "require-sri":                 "off",
    "no-inline-style":             "off",
    "long-title":                  "off",
    "heading-level":               "warn",
    "no-dup-id":                   "error",
    "valid-id":                    "error",
    "aria-label-misuse":           "error",
    "no-abstract-roles":           "error",
    "prefer-native-element":       "off",
    "element-required-attributes": "off",
    "no-missing-references":       "off",
    "script-type":                 "off",
    "void-style":                  "off",
    "attr-quotes":                 "off",
    "doctype-style":               "off",
    "meta-refresh":                "error",
    "no-trailing-whitespace":      "off",
    "deprecated":                  "warn",
    "wcag/h37":                    "off",
    "wcag/h67":                    "off",
    "wcag/h71":                    "off"
  }
}
