{
  "extends": ["html-validate:recommended"],
  "rules": {
    "doctype-style":               "omit",
    "require-sri":                 "off",
    "no-inline-style":             "off",
    "long-title":                  "off",
    "heading-level":               "warn",
    "label-missing-associated-control": "off",
    "element-required-attributes": "error",
    "attribute-boolean-style":    "error",
    "attribute-empty-style":      "error",
    "id-uniqueness":               "error",
    "no-dup-attr":                 "error",
    "no-dup-id":                   "error",
    "no-unknown-elements":         "warn",
    "script-type":                 "error",
    "void-content":                "error",
    "void-style":                  "error"
  }
}
