{
  "name": "portfolio-bryan-wambo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Personal cybersecurity portfolio — Bryan Wambo",
  "scripts": {
    "lint:js":    "eslint js/",
    "lint:css":   "stylelint 'css/**/*.css' --config .stylelintrc.json",
    "lint:html":  "html-validate index.html --config .htmlvalidate.json",
    "lint":       "npm run lint:html && npm run lint:css && npm run lint:js",
    "serve":      "serve . --listen 8080",
    "check:vars": "python3 scripts/check_css_vars.py",
    "lhci":       "lhci autorun --config=lighthouserc.json"
  },
  "devDependencies": {
    "@eslint/js":                "^9.0.0",
    "@lhci/cli":                 "^0.13.0",
    "eslint":                    "^9.0.0",
    "html-validate":             "^9.0.0",
    "serve":                     "^14.0.0",
    "stylelint":                 "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
